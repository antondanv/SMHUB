APP_NAME=SMHUB
APP_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smhub_db

SECRET_KEY=change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMTP. Оставьте SMTP_HOST пустым — письма уйдут в логи backend (dev-режим).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

FRONTEND_BASE_URL=http://localhost:5173
EMAIL_CONFIRM_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
