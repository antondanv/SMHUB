APP_NAME=SMHUB
APP_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smhub_db

SECRET_KEY=change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Resend (https://resend.com). Пустой RESEND_API_KEY — письма уйдут в логи backend (dev-режим).
# RESEND_FROM = адрес отправителя; для теста подойдёт onboarding@resend.dev,
# для прода — адрес на верифицированном домене.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

FRONTEND_BASE_URL=http://localhost:5173
EMAIL_CONFIRM_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
