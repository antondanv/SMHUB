{
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/app/main.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "frontend/assets/$1"
    },
    {
      "source": "/(.+\\.(?:js|css|map|json|txt|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|otf|eot|mp4|webm|wasm|pdf))",
      "destination": "frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}
